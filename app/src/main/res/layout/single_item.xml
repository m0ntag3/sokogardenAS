<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#1A1A1A"
    android:layout_height="wrap_content">

<!--    Below is a cardView-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        app:cardElevation="15dp"
        app:cardCornerRadius="12dp">

<!--    Below is another LinearLayout dictating how the contents will be aligned-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="#252525">

<!--            Below is the first TextView-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_name"
                android:text="Product Name"
                android:textSize="25sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/adlam_display"/>

<!--            Below is the product-image-->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:id="@+id/product_photo"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"
                android:layout_marginTop="9dp"/>

<!--            Below is a TextView for the product_cost-->
            <TextView
                android:id="@+id/product_cost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:fontFamily="@font/aclonica"
                android:text="KES. 500"
                android:textColor="#88751d"
                android:textStyle="bold"
                android:textSize="30sp"
                android:textAlignment="center"/>

<!--            Below is a TextView for the product_description-->
            <TextView
                android:id="@+id/product_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/aladin"
                android:text="Product description with appear here"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:layout_marginLeft="10dp"
                android:textStyle="bold"
                android:layout_marginTop="9dp"/>

<!--            Below is the Purchase button-->
            <Button
                android:id="@+id/btnPurchase"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="9dp"
                android:backgroundTint="#88751d"
                android:fontFamily="@font/alata"
                android:text="Purchase now"
                android:textAllCaps="false"
                android:textColor="#043927"
                android:textSize="28sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
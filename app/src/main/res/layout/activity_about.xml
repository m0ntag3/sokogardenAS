<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#1A1A1A"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".About">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="About Us"
        android:textStyle="bold"
        android:textSize="32sp"
        android:textColor="@color/white"
        android:textAlignment="center"
        android:fontFamily="@font/adlam_display"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp"
        app:cardElevation="18dp"
        android:padding="10dp"
        app:cardBackgroundColor="#252525"
        app:cardCornerRadius="15dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_margin="10dp"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/abouttxt"
                android:textSize="23sp"
                android:text="Welcome to our ecommerce application that is a simple user friendly platform designed to make online shopping easy and accessible for everyone. Users can quickly create accounts, securely login and browse a wide range of products in detailed description and product photos. Our seamless checkout process allows users to conveniently pay via M-pesa. We are happy and look forward to doing business with you."
                android:textColor="@color/white"
                android:fontFamily="@font/adlam_display"
                android:textAlignment="center"
                android:layout_marginTop="10dp"/>

            <Button
                android:id="@+id/btnListen"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#043927"
                android:fontFamily="@font/aladin"
                android:text="Know us"
                android:textAllCaps="true"
                android:textColor="#F9F4F0"
                android:layout_marginTop="15dp"
                android:textSize="25sp"
                app:cornerRadius="12dp" />


        </LinearLayout>


    </androidx.cardview.widget.CardView>

</LinearLayout>
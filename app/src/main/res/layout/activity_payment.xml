<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A"
    tools:context=".PaymentActivity">

<!--    Below is a TextView-->


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginLeft="20dp"
        android:background="#88751d"
        android:fontFamily="@font/adlam_display"
        android:text="Complete Payment via M-pesa"
        android:textAlignment="center"
        android:textColor="#0f5c03"
        android:textSize="32sp"
        android:textStyle="bold" />

<!--    Below is a cardview holding the contents-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:cardElevation="12dp"
        app:cardCornerRadius="12dp">

<!--        Below is a LinearLayout-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#252525">

<!--            Below is a TextView where the name of the product is to be attached/bound -->
            <TextView
                android:id="@+id/txtProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/amaranth_bold"
                android:text="Product Name"
                android:textColor="#FFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textAlignment="center"/>

<!--            Below is an ImageView-->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:id="@+id/imgProduct"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"
                android:layout_marginTop="10dp"
                android:layout_marginRight="20dp"
                android:layout_marginLeft="20dp"/>

<!--            Below is a TextView containing the product_description-->
            <TextView
                android:id="@+id/txtProductDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9sp"
                android:fontFamily="@font/amaranth"
                android:textAlignment="center"
                android:text="This is the description"
                android:textColor="@color/white"
                android:textSize="22sp" />


<!--            Below is a TextView for the product_cost-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductCost"
                android:text="KES. 1500"
                android:textSize="30sp"
                android:fontFamily="@font/aclonica"
                android:textColor="#88751d"
                android:layout_marginTop="9dp"
                android:textStyle="bold"
                android:textAlignment="center"/>



<!--            Below is an EditText for entering mobile number-->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Phone Number (+254#########)"
                android:textColorHint="#666666"
                app:boxStrokeColor="#D4AF37"
                app:hintTextColor="#D4AF37">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="#FFFFFF" />
            </com.google.android.material.textfield.TextInputLayout>

<!--            Below is a button to complete the payment function-->
            <Button
                android:id="@+id/pay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#0b3c03"
                android:fontFamily="@font/aladin"
                android:textColor="@color/white"
                android:text="PAY NOW"
                android:textSize="18sp"
                app:cornerRadius="12dp" />


        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>